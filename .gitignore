node_modules/
dist/
coverage/

# Test corpus — metadata is tracked, media files are not. Regenerate
# them locally with `npm run setup-corpus` (see tools/fetch-corpus.mjs).
# Synthetic clips are deterministically rebuilt from ffmpeg lavfi
# sources; external samples (Truepic zoetrope, Adobe c2pa-js pack) are
# documented in their NOTICE.md and must be fetched once from upstream.
corpus/*
!corpus/.gitkeep
!corpus/README.md
!corpus/corpus.json
!corpus/adobe-c2pa-js/
!corpus/c2pa-org-public/
!corpus/synth/
!corpus/synth-xmp/

# Inside each subtree, track only the metadata (.json / NOTICE.md /
# .gitkeep) — any binary media extension is ignored.
corpus/**/*.mp4
corpus/**/*.m4v
corpus/**/*.m4a
corpus/**/*.m4s
corpus/**/*.mov
corpus/**/*.mp3
corpus/**/*.wav
corpus/**/*.webm
corpus/**/*.webp
corpus/**/*.jpg
corpus/**/*.jpeg
corpus/**/*.png
corpus/**/*.gif

# Generated reports and scratch work. sample-run.json is the canonical
# reference run committed with the repo so readers can see the JSON report
# shape without having to run the matrix themselves.
reports/*
!reports/.gitkeep
!reports/sample-run.json
work/

# sign-corpus.mjs caches public test credentials here on demand.
# Treated as untrusted test material even though they are public.
tools/.cache/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
.env
.env.local

# Tarballs from npm pack
*.tgz

# ffmpeg scratch at repo root (init segments, one-off probes)
/init.mp4
/init.m4s
